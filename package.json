{
  "name": "memory-extract",
  "description": "Tool for embedding data into PNG images",
  "license": "MIT",
  "version": "0.1.13",
  "author": {
    "name": "semigarden",
    "url": "https://github.com/semigarden"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semigarden/memory-extract.git"
  },
  "type": "module",
  "files": [
    "src",
    "tools",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./node": "./tools/memoryFormat.mjs",
    "./payload": "./src/payloadFormat.js",
    "./play": "./src/memoryPlay.js",
    "./play/lifecycle": "./src/memoryPlayLifecycle.js",
    "./play/server": "./tools/playMemoryServer.mjs"
  },
  "bin": {
    "me": "./tools/memoryExtract.mjs"
  },
  "scripts": {
    "pack": "node tools/memoryExtract.mjs pack",
    "unpack": "node tools/memoryExtract.mjs unpack",
    "play": "node tools/memoryExtract.mjs play",
    "build": "node tools/buildBinaries.mjs"
  },
  "pkg": {
    "assets": [
      "src/**/*",
      "tools/**/*"
    ],
    "targets": [
      "node22-linux-x64"
    ],
    "outputPath": "dist",
    "sea": true
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
